{
  "manifest_version": 3,
  "name": "My TikTok Analytics Backup",
  "version": "0.1.0",
  "description": "Personal tool for TikTok creators to back up their own Studio analytics to a CSV file for offline review and self-tracking.",
  "permissions": ["storage", "tabs", "scripting", "downloads"],
  "host_permissions": ["*://*.tiktok.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Export TikTok Analytics",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
